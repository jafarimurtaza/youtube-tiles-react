{
  "name": "youtube-tiles-react",
  "version": "0.1.3",
  "description": "A responsive React grid of YouTube video thumbnails with a built-in lightbox player. Self-contained CSS, no Tailwind required.",
  "keywords": [
    "react",
    "youtube",
    "video",
    "lightbox",
    "gallery",
    "thumbnails",
    "tiles"
  ],
  "license": "MIT",
  "author": "Onepoint",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
